  const entrar = () => {
    setMensagem("Seja bem-vindo ao app!");
  };

  return (
    <View style={styles.container}>
      
      <Text style={styles.welcomeText}>
        {mensagem}
      </Text>

      <Button 
        title="Entrar" 
        onPress={entrar} 
      />

    </View>
  );
}

